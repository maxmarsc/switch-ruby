@PACKAGE_INIT@

# These are set as plain variables, not target properties,
# because custom properties don't survive install(EXPORT)
set(Ruby_VERSION     "@RUBY_VERSION@")
set(Ruby_TARGET_ARCH "@RUBY_TARGET_ARCH@")

# set_and_check() is provided by @PACKAGE_INIT@ — it checks the path exists
# and errors with a helpful message if not. Use it for all paths.
set_and_check(Ruby_INCLUDE_DIR
    "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@/ruby-@RUBY_VERSION@")

set_and_check(Ruby_ARCH_INCLUDE_DIR
    "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@/ruby-@RUBY_VERSION@/@RUBY_TARGET_ARCH@")

set(Ruby_INCLUDE_DIRS "${Ruby_INCLUDE_DIR}" "${Ruby_ARCH_INCLUDE_DIR}")

set_and_check(Ruby_LIBRARY
    "@PACKAGE_CMAKE_INSTALL_LIBDIR@/libruby-static.a")

set_and_check(Ruby_EXTINIT
    "@PACKAGE_CMAKE_INSTALL_LIBDIR@/ext/extinit.o")

set_and_check(Ruby_ENCINIT
    "@PACKAGE_CMAKE_INSTALL_LIBDIR@/enc/encinit.o")

set_and_check(Ruby_RUBYLIBDIR
    "@PACKAGE_CMAKE_INSTALL_LIBDIR@/ruby/@RUBY_VERSION@")

# Include the exported targets file (generated by install(EXPORT ...))
include("${CMAKE_CURRENT_LIST_DIR}/RubyTargets.cmake")

# -------------------------------------------------
# We do this here because CMake's install(EXPORT) strips absolute prefixes from 
# INTERFACE_LINK_LIBRARIES, which causes the linker to fail with "-llib/libruby-static.a".

# Gather all absolute paths (PACKAGE_CMAKE_INSTALL_LIBDIR is fully absolute here)
set(_Ruby_STATIC_ARCHIVES "") #
foreach(_rel IN ITEMS @RUBY_EXT_LIBS_REL@)
    list(APPEND _Ruby_STATIC_ARCHIVES "@PACKAGE_CMAKE_INSTALL_LIBDIR@/${_rel}")
endforeach()

# Prepend them to the target's link libraries so they link before system libs (zlib, libnx, m)
get_property(_current_libs TARGET Ruby::ruby PROPERTY INTERFACE_LINK_LIBRARIES)
set_property(TARGET Ruby::ruby PROPERTY INTERFACE_LINK_LIBRARIES
    ${Ruby_EXTINIT}
    ${Ruby_ENCINIT}
    ${Ruby_LIBRARY}
    "-Wl,--whole-archive"
    ${_Ruby_STATIC_ARCHIVES}
    "-Wl,--no-whole-archive"
    ${_current_libs}
)
# -------------------------------------------------

# Include the helper functions (romfs setup)
include("${CMAKE_CURRENT_LIST_DIR}/RubySwitchHelpers.cmake")

# check_required_components is also from PACKAGE_INIT
# It validates that all COMPONENTS requested by the consumer were found
check_required_components(Ruby)